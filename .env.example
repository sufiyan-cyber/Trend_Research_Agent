# Copy this file to .env and fill in your key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-key-here

# Models — Flash everywhere except final synthesis (cost guardrail)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_COMPOSER_MODEL=gemini-2.5-pro

# Storage: local JSON store by default. Set ONE of these to switch backend
# (or force with STORE_BACKEND=local|mongo|firebase):
# MONGODB_URI=mongodb+srv://...            # MongoDB (free Atlas tier)
# MONGODB_DB=trend_agent
# FIREBASE_CREDENTIALS=serviceAccount.json # Firestore (free Spark tier) — path to service-account JSON
# FIREBASE_PROJECT_ID=

# Vector memory: embedded local Qdrant by default (no Docker); set a URL to use a server
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Trend Radar schedule (server-local time)
RADAR_ENABLED=true
SCAN_HOUR=7
DIGEST_WEEKDAY=mon
DIGEST_HOUR=8
MARKET_MAP_DAY=1

# Crawl triage survivors for full text + page screenshot (Crawl4AI + Playwright)
CRAWL_ENABLED=true
CRAWL_TIMEOUT_S=30

# Optional: POST rising-trend alerts to a webhook (Slack/Discord)
# ALERT_WEBHOOK=
